{
  "name": "today",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "wrangler types",
    "wrangler:config": "bun run scripts/wrangler-env-config.ts",
    "dev": "bun run wrangler:config && WRANGLER_CONFIG_PATH=wrangler.local.jsonc vite",
    "build": "bun run wrangler:config && WRANGLER_CONFIG_PATH=wrangler.local.jsonc vite build",
    "deploy": "bun run build && wrangler deploy",
    "preview": "vite preview",
    "tunnel": "bun run scripts/tunnel.ts",
    "typecheck": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "bun run wrangler:config && wrangler d1 migrations apply today --local --config wrangler.local.jsonc",
    "db:migrate:remote": "bun run wrangler:config && wrangler d1 migrations apply today --remote --config wrangler.local.jsonc",
    "cf-typegen": "bun run wrangler:config && wrangler types --config wrangler.local.jsonc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.98.0",
    "@hono/oauth-providers": "0.8.5",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "qrcode-terminal": "0.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.38.0",
    "@types/qrcode-terminal": "0.12.2",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "vite": "8.0.14",
    "wrangler": "4.94.0"
  }
}
