# Copy this to .dev.vars for local Worker dev.
# Private deployment config is read from .env / .dev.vars and written to
# gitignored wrangler.local.jsonc by `bun run wrangler:config`.

CLOUDFLARE_WORKER_NAME=today
CLOUDFLARE_D1_DATABASE_NAME=today
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_CUSTOM_DOMAIN=
VITE_ALLOWED_HOSTS=

GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/auth/google/callback
ALLOWED_EMAIL=you@example.com
TIMEZONE=UTC
TRANSPORT_DEFAULT=TRANSIT
TRANSPORT_RESCUE=DRIVE
BUFFER_MINUTES=10

TODOIST_API_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_API_KEY=
SESSION_SECRET=
ANTHROPIC_API_KEY=

# YNAB_PAT=
